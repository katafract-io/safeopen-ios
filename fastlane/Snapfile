# Katafract screenshot pipeline — fastlane snapshot config

project("./SafeOpen.xcodeproj")

devices([
  "iPhone 17 Pro Max",
  "iPad Pro 13-inch (M5)"
])

languages(["en-US"])

# UI test scheme name
# Use the APP scheme — it now includes SafeOpenUITests in TestAction Testables (buildForTesting=YES)
# AND in TestAction.Testables. The SafeOpenUITests scheme has no LaunchAction app ref so it can't
# run UI tests on its own. The app scheme launches SafeOpen.app and runs the test bundle
# against it, which is the actual fastlane snapshot pattern.
scheme("SafeOpen")

output_directory("./fastlane/screenshots")
clear_previous_screenshots(true)
override_status_bar(true)
override_status_bar_arguments("--time 9:41 --batteryState charged --batteryLevel 100")

launch_arguments([
  "--screenshots --skip-onboarding",
])

skip_open_summary(true)
concurrent_simulators(true)
